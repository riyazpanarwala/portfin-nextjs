generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String      @id @default(uuid())
  email       String      @unique
  displayName String?     @map("display_name")
  createdAt   DateTime    @default(now()) @map("created_at")
  portfolios  Portfolio[]

  @@map("users")
}

model Portfolio {
  id        String     @id @default(uuid())
  userId    String     @map("user_id")
  name      String     @default("My Portfolio")
  createdAt DateTime   @default(now()) @map("created_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades    Trade[]
  snapshots Snapshot[]

  @@map("portfolios")
}

model Instrument {
  id             String    @id @default(uuid())
  symbol         String
  isin           String?   @unique
  name           String
  sector         String?
  exchange       Exchange
  assetType      AssetType @map("asset_type")
  price          Decimal?  @db.Decimal(12, 4)
  priceUpdatedAt DateTime? @map("price_updated_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  trades Trade[]

  @@unique([symbol, exchange])
  @@index([symbol])
  @@index([assetType])
  @@index([exchange, assetType])
  @@map("instruments")
}

model Trade {
  id           String    @id @default(uuid())
  portfolioId  String    @map("portfolio_id")
  instrumentId String    @map("instrument_id")
  tradeType    TradeType @map("trade_type")
  quantity     Decimal   @db.Decimal(18, 6)
  price        Decimal   @db.Decimal(12, 4)
  brokerage    Decimal?  @db.Decimal(10, 4)
  tradeDate    DateTime  @map("trade_date") @db.Date
  createdAt    DateTime  @default(now()) @map("created_at")

  portfolio  Portfolio  @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  instrument Instrument @relation(fields: [instrumentId], references: [id])

  @@index([portfolioId])
  @@index([portfolioId, instrumentId])
  @@index([tradeDate])
  @@map("trades")
}

model Snapshot {
  id             String   @id @default(uuid())
  portfolioId    String   @map("portfolio_id")
  totalValue     Decimal  @map("total_value") @db.Decimal(18, 2)
  totalInvested  Decimal  @map("total_invested") @db.Decimal(18, 2)
  totalGain      Decimal  @map("total_gain") @db.Decimal(18, 2)
  totalReturnPct Decimal  @map("total_return_pct") @db.Decimal(8, 2)
  mfCagr         Decimal? @map("mf_cagr") @db.Decimal(8, 2)
  mfInvested     Decimal? @map("mf_invested") @db.Decimal(18, 2)
  stInvested     Decimal? @map("st_invested") @db.Decimal(18, 2)
  fundCount      Int?     @map("fund_count")
  stockCount     Int?     @map("stock_count")
  snapshotAt     DateTime @default(now()) @map("snapshot_at")

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, snapshotAt])
  @@index([portfolioId, snapshotAt(sort: Desc)])
  @@map("snapshots")
}

enum AssetType {
  MF
  STOCK
}

enum TradeType {
  BUY
  SELL
}

enum Exchange {
  NSE
  BSE
  AMFI
}
